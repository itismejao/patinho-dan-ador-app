# Copie para android/keystore.properties (esse SIM é gitignored) e preencha
# com os dados do keystore de release. NUNCA versione o keystore.properties real.
#
# Gere o keystore uma única vez (guarde-o e as senhas para SEMPRE — perder o
# keystore de upload significa não conseguir mais atualizar o app na Play Store):
#
#   keytool -genkey -v -keystore ~/keys/patinho-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias patinho-upload
#
storeFile=/Users/SEU_USUARIO/keys/patinho-upload.jks
storePassword=SUA_SENHA_DO_STORE
keyAlias=patinho-upload
keyPassword=SUA_SENHA_DA_KEY
